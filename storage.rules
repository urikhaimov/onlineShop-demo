rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---- Helpers ----
    function authed() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isAdminOrSuperadmin() {
      return authed() && role() in ['admin', 'superadmin'];
    }

    function isImage() {
      // request.resource is only available on writes
      return request.resource != null &&
             request.resource.contentType.matches('image/.*');
    }

    function max10mb() {
      return request.resource != null &&
             request.resource.size < 10 * 1024 * 1024;
    }

    function max20mb() {
      return request.resource != null &&
             request.resource.size < 20 * 1024 * 1024;
    }

    // === Public user avatars ===
    // Example: avatars/{uid}/avatar.jpg
    match /avatars/{uid}/{file=**} {
      // Publicly readable avatars
      allow read: if true;

      // Only the owner can write; must be image and < 10MB
      allow write: if authed() &&
                   request.auth.uid == uid &&
                   isImage() &&
                   max10mb();
    }

    // === Product images ===
    // Example: products/{productId}/image.png
    match /products/{productId}/{file=**} {
      // Publicly readable product images
      allow read: if true;

      // Only admins/superadmins; image only; < 10MB
      allow write: if isAdminOrSuperadmin() &&
                   isImage() &&
                   max10mb();
    }

    // === Temporary uploads ===
    // Example: temp/{uid}/anything.tmp
    match /temp/{uid}/{file=**} {
      // Owner can read/write. Only check size on writes (request.resource is null on reads).
      allow read:  if authed() && request.auth.uid == uid;
      allow write: if authed() && request.auth.uid == uid && max20mb();
      // If you want images-only here too, replace max20mb() with (isImage() && max20mb()).
    }

    // === Fallback: deny all other paths ===
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
