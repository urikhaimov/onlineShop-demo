  "scripts": {
    "test": "pnpm nx test client",
    "test:rules": "cross-env PROJECT_ID=onlinestoretemplate-59d3e firebase emulators:exec --only firestore,storage \"vitest run -t rules\"",
    "lint": "eslint --cache --fix .",
    "nx:all": "npx nx run-many --target=build --all",
    "nx:run-all": "npx nx run-many -p auth api client --target=serve",
    "nx:latest": "npm i -g nx && npx nx migrate latest && npx nx --version",
    "test:e2e": "playwright test apps/client-e2e",
    "prepare": "husky install",
    "emu:start": "firebase emulators:start --import ./.emu-data --export-on-exit ./.emu-data",
    "emu:exec": "firebase emulators:exec --project onlinestoretemplate-59d3e",
    "emu:seed:auth": "cross-env GCLOUD_PROJECT=onlinestoretemplate-59d3e GOOGLE_CLOUD_PROJECT=onlinestoretemplate-59d3e FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 node scripts/seed-auth.js",
    "emu:seed:firestore": "cross-env GCLOUD_PROJECT=onlinestoretemplate-59d3e GOOGLE_CLOUD_PROJECT=onlinestoretemplate-59d3e FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/seed-firestore.js",
    "emu:seed:storage": "cross-env GCLOUD_PROJECT=onlinestoretemplate-59d3e GOOGLE_CLOUD_PROJECT=onlinestoretemplate-59d3e STORAGE_EMULATOR_HOST=http://127.0.0.1:9199 node scripts/seed-storage.js",
    "emu:purge-seed": "node scripts/emu-purge-seed.js",
    "smoke:auth": "node scripts/auth-smoke.mjs",
    "smoke:client": "node scripts/client-smoke.mjs",
    "smoke:api": "node scripts/api-smoke.mjs",
    "smoke:storage": "node scripts/storage-smoke.mjs",
    "smoke:all": "node scripts/auth-smoke.mjs && node scripts/client-smoke.mjs && node scripts/api-smoke.mjs && node scripts/storage-smoke.mjs",
    "api:dev": "cross-env GCLOUD_PROJECT=onlinestoretemplate-59d3e GOOGLE_CLOUD_PROJECT=onlinestoretemplate-59d3e FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 STORAGE_EMULATOR_HOST=http://127.0.0.1:9199 nx serve api",
    "web:dev": "nx serve client",
    "dev": "concurrently -k -n EMU,API,WEB \"npm:emu:start\" \"npm:api:dev\" \"npm:web:dev\"",
    "export:prod:firestore": "node scripts/export-prod.js",
    "import:emu": "node scripts/import-emu.js",
    "emu:start:core": "firebase emulators:start --config ./firebase.json --project onlinestoretemplate-59d3e --only auth,firestore,storage,ui --import ./.emu-data --export-on-exit ./.emu-data",
    "emu:start:full": "firebase emulators:start --config ./firebase.json --project onlinestoretemplate-59d3e --only auth,firestore,storage,functions,hosting,ui --import ./.emu-data --export-on-exit ./.emu-data"
  },
  "lint-staged": {
    "*.{json,mdx}": "npx prettier --write",
    "*.less": [
      "npx prettier --write",
      "stylelint \"**/*.less\" --fix --color --custom-syntax postcss-less --formatter verbose"
    ],
    "*.{js,ts,jsx,tsx}": [
      "npx prettier --write",
      "eslint --cache --fix"
    ]
