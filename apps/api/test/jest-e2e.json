{
  "moduleFileExtensions": ["js", "json", "ts"],
  "testEnvironment": "node",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testRegex": ".*\\.e2e[-\\.]?(spec|test)\\.ts$",
  "setupFiles": ["<rootDir>/apps/api/test/jest.setup.ts"],
  "collectCoverage": true,
  "coverageDirectory": "<rootDir>/coverage/api-e2e",
  "collectCoverageFrom": [
    "<rootDir>/apps/api/src/**/*.(t|j)s",
    "!<rootDir>/apps/api/src/main.(t|j)s",
    "!<rootDir>/**/__mocks__/**",
    "!<rootDir>/**/index.(t|j)s"
  ],
  "coverageThreshold": {
    "global": {
      "statements": 80,
      "branches": 70,
      "functions": 80,
      "lines": 80
    }
  }
}
