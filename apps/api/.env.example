# --- Server ---
NODE_ENV=development
APP_PORT=3000
API_PREFIX=api
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
DEFAULT_CURRENCY=ILS

# --- Firebase Admin ---
ADMIN_PROJECT_ID=your-project-id
ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FB_ADMIN_PROJECT_ID=your-project-id
ADMIN_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# --- PayPal ---
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_SANDBOX=true
SEND_PAYPAL_EMAILS_FROM_ORDERS=true

# --- Wolt integration (optional) ---
WOLT_MERCHANT_ID=
WOLT_MERCHANT_KEY=
WOLT_VENUE_ID=
WOLT_WEBHOOK_CLIENT_SECRET=
WOLT_BASE_URL=https://daas-public-api.wolt.com
WOLT_CURRENCY=EUR
WOLT_MS_URL=http://localhost:3101/wolt

# --- Mail ---
MAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_SANDBOX=false
EMAIL_FROM="Your Shop <orders@yourshop.app>"
MAIL_FROM=orders@yourshop.app
MAIL_FROM_NAME=Your Shop
MAIL_BRAND_NAME=Your Shop
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=SG.your_sendgrid_api_key

# --- Company ---
COMPANY_NAME="Your Shop"
COMPANY_VAT_ID=""
COMPANY_ADDRESS=""
COMPANY_PHONE=""
