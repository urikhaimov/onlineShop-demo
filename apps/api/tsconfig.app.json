{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/api",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "ignoreDeprecations": "6.0"
  },
  "files": ["src/main.ts"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"],
  "include": ["src/**/*"]
}
