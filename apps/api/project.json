{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{workspaceRoot}/dist/apps/api"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/main.ts",
        "tsConfig": "apps/api/tsconfig.app.json",
        "webpackConfig": "apps/api/webpack.config.js",
        "generatePackageJson": false,
        "externalDependencies": ["mjml", "handlebars"],
        "assets": [
          { "input": "apps/api/src/i18n", "glob": "**/*", "output": "i18n" },
          {
            "input": "libs/email-templates/src/templates",
            "glob": "**/*.mjml",
            "output": "libs/email-templates/templates"
          },
          {
            "input": "libs/email-templates/src/templates/assets",
            "glob": "**/*",
            "output": "libs/email-templates/templates/assets"
          }
        ]
      },
      "configurations": {
        "development": { "optimization": false, "sourceMap": true },
        "production": { "optimization": true, "sourceMap": false }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "api:build:development",
        "watch": true
      },
      "configurations": {
        "development": { "buildTarget": "api:build:development" },
        "production": { "buildTarget": "api:build:production" }
      }
    },
    "test": { "options": { "passWithNoTests": true } }
  }
}
