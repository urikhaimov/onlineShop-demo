{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{workspaceRoot}/dist/apps/api"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/main.ts",
        "tsConfig": "apps/api/tsconfig.app.json",
        "webpackConfig": "apps/api/webpack.config.js",
        "generatePackageJson": true,
        "externalDependencies": "all",
        "assets": [
          { "input": "apps/api/src/i18n", "glob": "**/*", "output": "i18n" },
          {
            "input": "apps/api/src/invoice/fonts",
            "glob": "**/*.ttf",
            "output": "invoice/fonts"
          },
          {
            "input": "libs/email-templates/src/lib/templates",
            "glob": "**/*.mjml",
            "output": "templates"
          }
        ]
      },
      "configurations": {
        "development": {
          "optimization": false,
          "sourceMap": true
        },
        "production": {
          "optimization": true,
          "sourceMap": false
        }
      }
    },
    "build-fast": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{workspaceRoot}/dist/apps/api"],
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/main.ts",
        "tsConfig": "apps/api/tsconfig.app.json",
        "generatePackageJson": false,
        "externalDependencies": "all",
        "format": ["cjs"],
        "assets": [
          {
            "input": "apps/api/src/i18n",
            "glob": "**/*",
            "output": "i18n"
          },
          {
            "input": "libs/email-templates/src/templates",
            "glob": "**/*.mjml",
            "output": "libs/email-templates/templates"
          },
          {
            "input": "apps/api/src/invoice/fonts",
            "glob": "**/*.ttf",
            "output": "invoice/fonts"
          }
        ]
      },
      "configurations": {
        "development": {
          "minify": false,
          "sourcemap": false
        },
        "production": {
          "minify": true,
          "sourcemap": false
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "api:build-fast",
        "watch": true,
        "inspect": false,
        "waitUntilTargets": ["api:build-fast"]
      },
      "configurations": {
        "development": {
          "buildTarget": "api:build-fast:development"
        },
        "production": {
          "buildTarget": "api:build:production"
        },
        "debug": {
          "buildTarget": "api:build-fast:development",
          "inspect": 9231
        }
      }
    },
    "test": { "options": { "passWithNoTests": true } }
  }
}
