rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Shared helper functions ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isAdminOrSuperadmin() {
      return isSignedIn() && request.auth.token.role in ['admin', 'superadmin'];
    }

    // Prevent users from setting/elevating role
    function noRoleOnCreate() {
      return !('role' in request.resource.data) || request.resource.data.role == 'user';
    }

    function noRoleChangeBySelf() {
      // if 'role' exists in current doc, it must stay the same;
      // if it doesn't exist, user can't add it
      return !('role' in request.resource.data) ||
             ( 'role' in resource.data && request.resource.data.role == resource.data.role );
    }

    // Your existing order helpers
    function isSettingPaymentToPaid() {
      return request.resource.data.payment.status == 'paid' &&
             request.resource.data.payment.status != resource.data.payment.status;
    }

    function isModifyingRestrictedFields() {
      return request.resource.data.internalTags != resource.data.internalTags ||
             request.resource.data.delivery.sla != resource.data.delivery.sla;
    }

    // === Products ===
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrSuperadmin();
    }

    // === Categories ===
    match /categories/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrSuperadmin();
    }

    // === Themes ===
    match /themes/{themeId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrSuperadmin();
    }

    // === Landing Pages ===
    match /landingPage/{pageId} {
      allow read: if true;
      allow create, update, delete: if isAdminOrSuperadmin();
    }

    // === Users ===
    match /users/{userId} {
      // Read: owner or admin/superadmin
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdminOrSuperadmin());

      // Create: only the signed-in user may create their own doc and cannot set role
      allow create: if isSignedIn()
                    && userId == request.auth.uid
                    && noRoleOnCreate();

      // Update:
      //  - owner may update but cannot change 'role'
      //  - admin/superadmin may update any user doc
      allow update: if isSignedIn() && (
                      (request.auth.uid == userId && noRoleChangeBySelf()) ||
                      isAdminOrSuperadmin()
                    );

      // Delete: owner OR admin/superadmin (keep both; tighten to only admin if you prefer)
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdminOrSuperadmin());
    }

    // === Orders ===
    match /orders/{orderId} {
      // creator must be the owner
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // read/update: owner or admin/superadmin
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || isAdminOrSuperadmin()
      );

      // owner can update only non-restricted fields and cannot flip payment to 'paid'
      // admin/superadmin can update freely
      allow update: if isSignedIn() && (
        (
          request.auth.uid == resource.data.userId &&
          !isModifyingRestrictedFields() &&
          !isSettingPaymentToPaid()
        ) || isAdminOrSuperadmin()
      );

      allow delete: if isAdminOrSuperadmin();
    }

    // === Abandoned Carts ===
    match /abandonedCarts/{clientSecret} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isAdminOrSuperadmin();
    }

    // === Fallback ===
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
